#ifndef INVERNADERO_H
#define INVERNADERO_H

    #include <iostream>
    using namespace std;


    enum EstadoDispositivo : uint8_t {
        OK = 0,
        DESCONECTADO = 1,
        VALOR_INVALIDO = 2
    };



    class Sensor {
    protected:
        int id;
            EstadoDispositivo estado;
            float lastReading;

    public:
        Sensor(int id);
        ~Sensor() {}

        virtual float leerValor() = 0;
        EstadoDispositivo obtenerEstado();
        virtual bool validarRango(float valor) = 0;
        int obtenerID();

    // Clases sensores
    class SensorHumedad : public Sensor {
    public:
        SensorHumedad(int id);
        float leerValor() override;
        bool validarRango(float val) override;
    };

    class SensorPH : public Sensor {
    public:
        SensorPH(int id);
        float leerValor() override;
    };

    class SensorTemperatura : public Sensor {
    public:
                SensorTemperatura(int id);
        float leerValor() override;
    };

    class SensorLuz : public Sensor {
    private:
        float umbralOscuridad;

    public:
        SensorLuz(int id, float umbral);
        float leerValor() override;
        bool esDeNoche();
    };

    // Clase abs
    class Actuador {
    protected:
        int id;
        EstadoDispositivo estado;

    public:
        Actuador(int id);
        ~Actuador() {}

        virtual void encender() = 0;
        virtual void apagar() = 0;
        EstadoDispositivo obtenerEstado();
        int obtenerID();
    };

        float readLastReading();
    };

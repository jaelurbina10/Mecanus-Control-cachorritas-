#ifndef INVERNADERO_H
#define INVERNADERO_H

    #include <iostream>
    using namespace std;


    enum EstadoDispositivo : uint8_t {
        OK = 0,
        DESCONECTADO = 1,
        VALOR_INVALIDO = 2
    };



    class Sensor {
    protected:
        int id;
            EstadoDispositivo estado;
            float lastReading;

    public:
        Sensor(int id);
        ~Sensor() {}

        virtual float leerValor() = 0;
        EstadoDispositivo obtenerEstado();
        virtual bool validarRango(float valor) = 0;
        int obtenerID();
        float readLastReading();
    };
